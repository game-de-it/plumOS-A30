# Local secrets and device-generated credentials. Tracked example/default files
# must use explicit non-secret names such as authorized_keys.example.
.env
.env.*
!.env.example
id_rsa*
id_ed25519*
*.pem
*.p12
*.pfx
known_hosts
authorized_keys
wpa_supplicant.conf
plumos/ssh/etc/authorized_keys
plumos/ssh/etc/dropbear_*_host_key
plumos/config/network/wpa_supplicant.conf

