+static int pa_vfs_trace_enabled(void)
+{
+	static int enabled = -1;
+	if (enabled < 0)
+		enabled = getenv("PLUMOS_PICOARCH_VFS_TRACE") ? 1 : 0;
+	return enabled;
+}
+
+static const char *pa_vfs_normalize_path(const char *path)
+{
+	const char *vfsonly_prefix = "vfsonly://";
+	size_t vfsonly_len = strlen(vfsonly_prefix);
+
+	if (path && !strncmp(path, vfsonly_prefix, vfsonly_len))
+		return path + vfsonly_len;
+	return path;
 }
 
