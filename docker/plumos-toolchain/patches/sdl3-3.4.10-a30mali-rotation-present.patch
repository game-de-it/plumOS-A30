+static A30MALI_GLuint A30MALI_CreateShader(A30MALI_GL *gl, A30MALI_GLenum type, const char *source)
+{
+    A30MALI_GLuint shader = gl->CreateShader(type);
+    A30MALI_GLint ok = 0;
+
+    if (!shader) {
+        return 0;
+    }
+    gl->ShaderSource(shader, 1, &source, NULL);
+    gl->CompileShader(shader);
+    gl->GetShaderiv(shader, A30MALI_GL_COMPILE_STATUS, &ok);
+    if (!ok) {
+        gl->DeleteShader(shader);
+        return 0;
+    }
+    return shader;
+}
