+static A30MALI_Rotation A30MALI_GetRotation(void)
+{
+    const char *value = SDL_getenv("PLUMOS_A30MALI_ROTATION");
+
+    if (!value || !*value) {
+        value = SDL_getenv("PLUMOS_A30_DISPLAY_ROTATION");
+    }
+    if (!A30MALI_StringEnabled(value)) {
+        return A30MALI_ROTATION_NONE;
+    }
+    if (SDL_strcasecmp(value, "cw") == 0 || SDL_strcasecmp(value, "90") == 0) {
+        return A30MALI_ROTATION_CW;
+    }
+    if (SDL_strcasecmp(value, "ccw") == 0 || SDL_strcasecmp(value, "270") == 0) {
+        return A30MALI_ROTATION_CCW;
+    }
+    return A30MALI_ROTATION_NONE;
+}
+
+static bool A30MALI_RotationSwapsAxes(A30MALI_Rotation rotation)
+{
+    return rotation == A30MALI_ROTATION_CW || rotation == A30MALI_ROTATION_CCW;
+}
