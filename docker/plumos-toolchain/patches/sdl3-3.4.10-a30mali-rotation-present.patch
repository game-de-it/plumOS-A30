+}
+
+static void A30MALI_ComputeFitMargins(A30MALI_Rotation rotation, int logical_width, int logical_height,
+                                      int physical_width, int physical_height,
+                                      A30MALI_GLfloat *margin_u, A30MALI_GLfloat *margin_v)
+{
+    float display_width = A30MALI_RotationSwapsAxes(rotation) ? (float)physical_height : (float)physical_width;
+    float display_height = A30MALI_RotationSwapsAxes(rotation) ? (float)physical_width : (float)physical_height;
+    float scale_x = display_width / (float)logical_width;
+    float scale_y = display_height / (float)logical_height;
+    float scale = scale_x < scale_y ? scale_x : scale_y;
+    float output_width = (float)logical_width * scale;
+    float output_height = (float)logical_height * scale;
+    float horizontal_margin = (display_width - output_width) / (2.0f * display_width);
+    float vertical_margin = (display_height - output_height) / (2.0f * display_height);
+
+    if (horizontal_margin < 0.0f) {
+        horizontal_margin = 0.0f;
+    }
+    if (vertical_margin < 0.0f) {
+        vertical_margin = 0.0f;
+    }
+
+    *margin_u = horizontal_margin;
+    *margin_v = vertical_margin;
+}
