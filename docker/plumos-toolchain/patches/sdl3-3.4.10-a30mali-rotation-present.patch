+static bool A30MALI_GetEnvSize(const char *name, int *width, int *height)
+{
+    const char *value = SDL_getenv(name);
+    const char *separator;
+    int parsed_width;
+    int parsed_height;
+
+    if (!value || !*value) {
+        return false;
+    }
+    separator = SDL_strchr(value, 'x');
+    if (!separator) {
+        separator = SDL_strchr(value, 'X');
+    }
+    if (!separator) {
+        return false;
+    }
+
+    parsed_width = SDL_atoi(value);
+    parsed_height = SDL_atoi(separator + 1);
+    if (parsed_width <= 0 || parsed_height <= 0 || parsed_width > 4096 || parsed_height > 4096) {
+        return false;
+    }
+
+    *width = parsed_width;
+    *height = parsed_height;
+    return true;
+}
