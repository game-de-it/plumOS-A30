+static unsigned a30_parse_env_unsigned(const char *name, unsigned fallback,
+                                       unsigned min_value,
+                                       unsigned max_value) {
+    const char *value = getenv(name);
+    char *end = NULL;
+    unsigned long parsed;
+
+    if (value == NULL || value[0] == '\0') return fallback;
+    parsed = strtoul(value, &end, 10);
+    if (end == value || *end != '\0' ||
+        parsed < min_value || parsed > max_value) {
+        return fallback;
+    }
+    return (unsigned)parsed;
+}
+
+static void a30_load_audio_config(void) {
+    audioQueueChunks =
+        a30_parse_env_unsigned("PLUMOS_A30_RED_VIPER_AUDIO_QUEUE_CHUNKS",
+                               BUF_COUNT / 2, 2, 64);
+    audioPrebufferChunks =
+        a30_parse_env_unsigned("PLUMOS_A30_RED_VIPER_AUDIO_PREBUFFER_CHUNKS",
+                               0, 0, audioQueueChunks);
+}
+
+static void a30_queue_silence(unsigned chunks) {
+    int16_t silence[SAMPLE_COUNT * 2];
+    memset(silence, 0, sizeof(silence));
+    for (unsigned i = 0; i < chunks; i++) {
+        if (SDL_QueueAudio(audioDevice, silence, audioChunkBytes) != 0) {
+            break;
+        }
+    }
+}
