+static int plumos_joypad_key_state(unsigned key)
+{
+   switch (key) {
+   case RETROK_UP:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_UP);
+   case RETROK_DOWN:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_DOWN);
+   case RETROK_LEFT:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_LEFT);
+   case RETROK_RIGHT:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_RIGHT);
+   case RETROK_SPACE:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_A);
+   case RETROK_LCTRL:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_B);
+   case RETROK_LSHIFT:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_X);
+   case RETROK_LALT:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_Y);
+   case RETROK_RETURN:
+   case RETROK_KP_ENTER:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_START);
+   case RETROK_ESCAPE:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_SELECT);
+   case RETROK_TAB:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_L);
+   case RETROK_BACKSPACE:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_R);
+   case RETROK_e:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_L2);
+   case RETROK_t:
+      return input_cb(0, RETRO_DEVICE_JOYPAD, 0, RETRO_DEVICE_ID_JOYPAD_R2);
+   default:
+      return 0;
+   }
+}
+
+static int plumos_key_state(unsigned key)
+{
+   return input_cb(0, RETRO_DEVICE_KEYBOARD, 0, key) || plumos_joypad_key_state(key);
+}
