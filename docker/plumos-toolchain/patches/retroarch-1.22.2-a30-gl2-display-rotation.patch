+            gl2_plumos_a30_default_mvp(gl));
@@ -2749 +2777 @@
-   gl->shader->set_mvp(gl->shader_data, &gl->mvp_no_rot);
+   gl->shader->set_mvp(gl->shader_data, gl2_plumos_a30_default_mvp(gl));
@@ -2967,0 +2996,3 @@
+   if (gl2_plumos_a30_display_rotation_enabled(gl))
+      RARCH_LOG("[plumOS] A30 display rotation enabled: video_rotation=%u degrees=%u.\n",
