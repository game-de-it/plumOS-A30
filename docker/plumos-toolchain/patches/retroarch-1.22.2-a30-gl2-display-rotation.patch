--- a/gfx/drivers/gl2.c
+++ b/gfx/drivers/gl2.c
@@ -375,0 +376,13 @@
+
+static bool gl2_plumos_a30_display_rotation_enabled(const gl2_t *gl)
+{
+   const char *rotation = getenv("PLUMOS_RA_DISPLAY_ROTATION");
+
+   if (     !gl
+         || !gl->ctx_driver
+         || !gl->ctx_driver->ident
+         || !string_is_equal(gl->ctx_driver->ident, "fbdev_mali"))
+      return false;
+
+   if (string_is_empty(rotation))
+      return false;
@@ -376,0 +390,15 @@
+   if (     string_is_equal(rotation, "none")
+         || string_is_equal(rotation, "normal")
+         || string_is_equal(rotation, "0"))
+      return false;
+
+   return true;
+}
+
+static math_matrix_4x4 *gl2_plumos_a30_default_mvp(gl2_t *gl)
+{
+   if (gl2_plumos_a30_display_rotation_enabled(gl))
+      return &gl->mvp;
+   return &gl->mvp_no_rot;
+}
+
@@ -384 +412 @@
-   return &gl->mvp_no_rot;
+   return gl2_plumos_a30_default_mvp(gl);
@@ -523 +551 @@
