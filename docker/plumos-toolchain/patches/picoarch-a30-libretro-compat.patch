+struct retro_vfs_file_handle {
+	FILE *file;
+	char *path;
+};
+
+struct retro_vfs_dir_handle {
+	DIR *dir;
+	struct dirent *entry;
+	char *path;
+	bool include_hidden;
+};
+
+static const char *pa_vfs_get_path(struct retro_vfs_file_handle *stream)
+{
+	return stream ? stream->path : NULL;
+}
+
+static struct retro_vfs_file_handle *pa_vfs_open(const char *path, unsigned mode, unsigned hints)
+{
+	struct retro_vfs_file_handle *stream;
+	const char *file_mode = "rb";
+	(void)hints;
+
+	if (!path)
+		return NULL;
+
+	if ((mode & RETRO_VFS_FILE_ACCESS_READ_WRITE) == RETRO_VFS_FILE_ACCESS_READ_WRITE)
+		file_mode = (mode & RETRO_VFS_FILE_ACCESS_UPDATE_EXISTING) ? "r+b" : "w+b";
+	else if (mode & RETRO_VFS_FILE_ACCESS_WRITE)
+		file_mode = (mode & RETRO_VFS_FILE_ACCESS_UPDATE_EXISTING) ? "r+b" : "wb";
+
+	stream = calloc(1, sizeof(*stream));
+	if (!stream)
+		return NULL;
+
+	stream->file = fopen(path, file_mode);
+	if (!stream->file && (mode & RETRO_VFS_FILE_ACCESS_WRITE) &&
+	    (mode & RETRO_VFS_FILE_ACCESS_UPDATE_EXISTING))
+		stream->file = fopen(path, "w+b");
+	if (!stream->file) {
+		free(stream);
+		return NULL;
+	}
+
+	stream->path = strdup(path);
+	return stream;
+}
+
+static int pa_vfs_close(struct retro_vfs_file_handle *stream)
+{
+	int ret = 0;
+	if (!stream)
+		return -1;
+	if (stream->file)
+		ret = fclose(stream->file);
+	free(stream->path);
+	free(stream);
+	return ret;
+}
+
+static int64_t pa_vfs_tell(struct retro_vfs_file_handle *stream)
+{
+	if (!stream || !stream->file)
+		return -1;
+	return ftello(stream->file);
+}
+
+static int64_t pa_vfs_seek(struct retro_vfs_file_handle *stream, int64_t offset, int seek_position)
+{
+	int whence = SEEK_SET;
+	if (!stream || !stream->file)
+		return -1;
+	switch (seek_position) {
+	case RETRO_VFS_SEEK_POSITION_CURRENT:
+		whence = SEEK_CUR;
+		break;
+	case RETRO_VFS_SEEK_POSITION_END:
+		whence = SEEK_END;
+		break;
+	default:
+		whence = SEEK_SET;
+		break;
+	}
+	if (fseeko(stream->file, offset, whence) != 0)
+		return -1;
+	return ftello(stream->file);
+}
+
+static int64_t pa_vfs_size(struct retro_vfs_file_handle *stream)
+{
+	off_t pos;
+	off_t end;
+	if (!stream || !stream->file)
+		return -1;
+	pos = ftello(stream->file);
+	if (fseeko(stream->file, 0, SEEK_END) != 0)
+		return -1;
+	end = ftello(stream->file);
+	fseeko(stream->file, pos, SEEK_SET);
+	return end;
+}
+
+static int64_t pa_vfs_truncate(struct retro_vfs_file_handle *stream, int64_t length)
+{
+	if (!stream || !stream->file)
+		return -1;
+	return ftruncate(fileno(stream->file), length);
+}
+
+static int64_t pa_vfs_read(struct retro_vfs_file_handle *stream, void *s, uint64_t len)
+{
+	if (!stream || !stream->file || !s)
+		return -1;
+	return fread(s, 1, len, stream->file);
+}
+
+static int64_t pa_vfs_write(struct retro_vfs_file_handle *stream, const void *s, uint64_t len)
+{
+	if (!stream || !stream->file || !s)
+		return -1;
+	return fwrite(s, 1, len, stream->file);
+}
+
+static int pa_vfs_flush(struct retro_vfs_file_handle *stream)
+{
+	if (!stream || !stream->file)
+		return -1;
+	return fflush(stream->file);
+}
+
+static int pa_vfs_remove(const char *path)
+{
+	return path ? remove(path) : -1;
+}
+
+static int pa_vfs_rename(const char *old_path, const char *new_path)
+{
+	return (old_path && new_path) ? rename(old_path, new_path) : -1;
+}
+
+static int pa_vfs_stat(const char *path, int32_t *size)
+{
+	struct stat st;
+	int flags = 0;
+	if (!path || stat(path, &st) != 0)
+		return 0;
+	flags |= RETRO_VFS_STAT_IS_VALID;
+	if (S_ISDIR(st.st_mode))
+		flags |= RETRO_VFS_STAT_IS_DIRECTORY;
+	if (S_ISCHR(st.st_mode))
+		flags |= RETRO_VFS_STAT_IS_CHARACTER_SPECIAL;
+	if (size)
+		*size = (int32_t)st.st_size;
+	return flags;
+}
+
+static int pa_vfs_mkdir(const char *dir)
+{
+	if (!dir)
+		return -1;
+	if (mkdir(dir, 0755) == 0 || errno == EEXIST)
+		return 0;
+	return -1;
+}
+
+static struct retro_vfs_dir_handle *pa_vfs_opendir(const char *dir, bool include_hidden)
+{
+	struct retro_vfs_dir_handle *stream;
+	if (!dir)
+		return NULL;
+	stream = calloc(1, sizeof(*stream));
+	if (!stream)
+		return NULL;
+	stream->dir = opendir(dir);
+	if (!stream->dir) {
+		free(stream);
+		return NULL;
+	}
+	stream->path = strdup(dir);
+	stream->include_hidden = include_hidden;
+	return stream;
 }
 
+static bool pa_vfs_readdir(struct retro_vfs_dir_handle *stream)
+{
+	if (!stream || !stream->dir)
+		return false;
+	while ((stream->entry = readdir(stream->dir))) {
+		if (stream->include_hidden || stream->entry->d_name[0] != '.')
+			return true;
+	}
+	return false;
+}
+
+static const char *pa_vfs_dirent_get_name(struct retro_vfs_dir_handle *stream)
+{
+	return (stream && stream->entry) ? stream->entry->d_name : NULL;
+}
+
+static bool pa_vfs_dirent_is_dir(struct retro_vfs_dir_handle *stream)
+{
+	char path[MAX_PATH];
+	struct stat st;
+	if (!stream || !stream->entry)
+		return false;
+#ifdef DT_DIR
+	if (stream->entry->d_type == DT_DIR)
+		return true;
+	if (stream->entry->d_type != DT_UNKNOWN)
+		return false;
+#endif
+	snprintf(path, sizeof(path), "%s/%s", stream->path, stream->entry->d_name);
+	return stat(path, &st) == 0 && S_ISDIR(st.st_mode);
+}
+
+static int pa_vfs_closedir(struct retro_vfs_dir_handle *stream)
+{
+	int ret = 0;
+	if (!stream)
+		return -1;
+	if (stream->dir)
+		ret = closedir(stream->dir);
+	free(stream->path);
+	free(stream);
+	return ret;
+}
+
+static struct retro_vfs_interface pa_vfs_interface = {
+	.get_path = pa_vfs_get_path,
+	.open = pa_vfs_open,
+	.close = pa_vfs_close,
+	.size = pa_vfs_size,
+	.tell = pa_vfs_tell,
+	.seek = pa_vfs_seek,
+	.read = pa_vfs_read,
+	.write = pa_vfs_write,
+	.flush = pa_vfs_flush,
+	.remove = pa_vfs_remove,
+	.rename = pa_vfs_rename,
+	.truncate = pa_vfs_truncate,
+	.stat = pa_vfs_stat,
+	.mkdir = pa_vfs_mkdir,
+	.opendir = pa_vfs_opendir,
+	.readdir = pa_vfs_readdir,
+	.dirent_get_name = pa_vfs_dirent_get_name,
+	.dirent_is_dir = pa_vfs_dirent_is_dir,
+	.closedir = pa_vfs_closedir,
+};
