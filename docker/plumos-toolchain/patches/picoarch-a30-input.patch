+static int read_menu_repeat_env(const char *name, int fallback, int min, int max)
+{
+	const char *env = getenv(name);
+	char *end = NULL;
+	long value;
+
+	if (!env || !env[0])
+		return fallback;
+	value = strtol(env, &end, 10);
+	if (end == env)
+		return fallback;
+	if (value < min)
+		value = min;
+	if (value > max)
+		value = max;
+	return (int)value;
+}
