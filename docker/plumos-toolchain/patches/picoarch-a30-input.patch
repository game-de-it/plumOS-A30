+static int force_default_menu_binds(void)
+{
+	int menu_mask = 1 << EACTION_MENU;
+	int dev_id;
+	int changed = 0;
+
+	for (dev_id = 0; dev_id < IN_MAX_DEVS; dev_id++) {
+		const int *binds;
+		const int *defbinds;
+		int kcount = 0;
+		int i;
+
+		if (in_get_config(dev_id, IN_CFG_BIND_COUNT, &kcount) != 0 || kcount <= 0)
+			continue;
+
+		binds = in_get_dev_binds(dev_id);
+		defbinds = in_get_dev_def_binds(dev_id);
+		if (!defbinds)
+			continue;
+
+		for (i = 0; i < kcount; i++) {
+			const char *key_name;
+
+			if (defbinds[IN_BIND_OFFS(i, IN_BINDTYPE_EMU)] != menu_mask)
+				continue;
+			if (binds && (binds[IN_BIND_OFFS(i, IN_BINDTYPE_EMU)] & menu_mask))
+				continue;
+			key_name = in_get_key_name(dev_id, i);
+			if (key_name && key_name[0] &&
+					in_config_bind_key(dev_id, key_name, menu_mask, IN_BINDTYPE_EMU) == 0)
+				changed = 1;
+		}
+	}
+	in_clean_binds();
+	return changed;
+}
