+static bool frontend_unix_plumos_write_restart_append(const char *path)
+{
+   FILE *file;
+   bool threaded;
+   bool *threaded_ptr;
+
+   if (string_is_empty(path))
+      return false;
+
+   threaded_ptr = video_driver_get_threaded();
+   threaded     = threaded_ptr ? *threaded_ptr : false;
+
+   file = fopen(path, "w");
+   if (!file)
+   {
+      RARCH_ERR("[plumOS] Failed to open restart append config \"%s\": %s.\n",
+            path, strerror(errno));
+      return false;
+   }
+
+   if (fprintf(file, "video_threaded = \"%s\"\n",
+         threaded ? "true" : "false") < 0)
+   {
+      RARCH_ERR("[plumOS] Failed to write restart append config \"%s\": %s.\n",
+            path, strerror(errno));
+      fclose(file);
+      return false;
+   }
+
+   if (fclose(file) != 0)
+   {
+      RARCH_ERR("[plumOS] Failed to close restart append config \"%s\": %s.\n",
+            path, strerror(errno));
+      return false;
    }

+   RARCH_LOG("[plumOS] Restart append config: \"%s\" video_threaded=%s.\n",
+         path, threaded ? "true" : "false");
    return true;
 }

