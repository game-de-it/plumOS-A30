+static bool PlumOSEnvEnabled(const char *value, bool defaultValue) {
+	if (value == nullptr || value[0] == '\0') {
+		return defaultValue;
+	}
+	if (!strcmp(value, "1") || !strcmp(value, "yes") || !strcmp(value, "true") || !strcmp(value, "on")) {
+		return true;
+	}
+	if (!strcmp(value, "0") || !strcmp(value, "no") || !strcmp(value, "false") || !strcmp(value, "off")) {
+		return false;
+	}
+	fprintf(stderr, "[plumOS] Ignoring unknown boolean value: %s\n", value);
+	return defaultValue;
+}
+
+static bool PlumOSParseSizeEnv(const char *value, int *width, int *height) {
+	if (value == nullptr || value[0] == '\0') {
+		return false;
+	}
+
+	char *end = nullptr;
+	long parsedWidth = strtol(value, &end, 10);
+	if (end == value || (*end != 'x' && *end != 'X' && *end != ',' && *end != ':')) {
+		fprintf(stderr, "[plumOS] Ignoring invalid display size: %s\n", value);
+		return false;
+	}
+
+	char *heightStart = end + 1;
+	long parsedHeight = strtol(heightStart, &end, 10);
+	if (end == heightStart || *end != '\0' || parsedWidth <= 0 || parsedHeight <= 0 || parsedWidth > 8192 || parsedHeight > 8192) {
+		fprintf(stderr, "[plumOS] Ignoring invalid display size: %s\n", value);
+		return false;
+	}
+
+	*width = (int)parsedWidth;
+	*height = (int)parsedHeight;
+	return true;
+}
+
+static bool PlumOSApplyLogicalDisplaySize(const char *value) {
+	int logicalWidth = 0;
+	int logicalHeight = 0;
+	if (!PlumOSParseSizeEnv(value, &logicalWidth, &logicalHeight)) {
+		return false;
+	}
+
+	g_display.dp_xres = logicalWidth;
+	g_display.dp_yres = logicalHeight;
+	if (g_display.pixel_xres > 0) {
+		g_display.dpi_scale_x = (float)g_display.dp_xres / (float)g_display.pixel_xres;
+		g_display.pixel_in_dps_x = (float)g_display.pixel_xres / (float)g_display.dp_xres;
+	}
+	if (g_display.pixel_yres > 0) {
+		g_display.dpi_scale_y = (float)g_display.dp_yres / (float)g_display.pixel_yres;
+		g_display.pixel_in_dps_y = (float)g_display.pixel_yres / (float)g_display.dp_yres;
+	}
+	return true;
+}
+
+static void ApplyPlumOSA30DisplayRotation() {
+	const char *value = getenv("PLUMOS_A30_DISPLAY_ROTATION");
+	DisplayRotation rotation = DisplayRotation::ROTATE_0;
+	const char *label = "none";
+	bool rotationSwapsAxes = false;
+
+	if (value == nullptr || value[0] == '\0' || !strcmp(value, "none") || !strcmp(value, "0")) {
+		rotation = DisplayRotation::ROTATE_0;
+		label = "none";
+	} else if (!strcmp(value, "ccw") || !strcmp(value, "90")) {
+		rotation = DisplayRotation::ROTATE_90;
+		label = "ccw";
+		rotationSwapsAxes = true;
+	} else if (!strcmp(value, "cw") || !strcmp(value, "270")) {
+		rotation = DisplayRotation::ROTATE_270;
+		label = "cw";
+		rotationSwapsAxes = true;
+	} else if (!strcmp(value, "180")) {
+		rotation = DisplayRotation::ROTATE_180;
+		label = "180";
+	} else {
+		fprintf(stderr, "[plumOS] Ignoring unknown PLUMOS_A30_DISPLAY_ROTATION=%s\n", value);
+		rotation = DisplayRotation::ROTATE_0;
+	}
+
+	g_display.rotation = rotation;
+	switch (rotation) {
+	case DisplayRotation::ROTATE_90:
+		g_display.rot_matrix.setRotationZ90();
+		break;
+	case DisplayRotation::ROTATE_180:
+		g_display.rot_matrix.setRotationZ180();
+		break;
+	case DisplayRotation::ROTATE_270:
+		g_display.rot_matrix.setRotationZ270();
+		break;
+	case DisplayRotation::ROTATE_0:
+	default:
+		g_display.rot_matrix.setIdentity();
+		break;
+	}
+
+	const bool swapDimensions = rotationSwapsAxes && PlumOSEnvEnabled(getenv("PLUMOS_A30_DISPLAY_SWAP"), false);
+	if (swapDimensions) {
+		std::swap(g_display.pixel_xres, g_display.pixel_yres);
+		std::swap(g_display.dp_xres, g_display.dp_yres);
+	}
+
+	const bool logicalOverride = PlumOSApplyLogicalDisplaySize(getenv("PLUMOS_A30_DISPLAY_LOGICAL"));
+	const bool forceLandscape = PlumOSEnvEnabled(getenv("PLUMOS_A30_DISPLAY_FORCE_LANDSCAPE"), false);
+	fprintf(stderr, "[plumOS] A30 display rotation=%s swap=%d logical=%d force_landscape=%d pixel=%dx%d dp=%dx%d dpi=%0.3fx%0.3f\n",
+	        label, swapDimensions ? 1 : 0, logicalOverride ? 1 : 0, forceLandscape ? 1 : 0, g_display.pixel_xres, g_display.pixel_yres, g_display.dp_xres, g_display.dp_yres, g_display.dpi_scale_x, g_display.dpi_scale_y);
+}
