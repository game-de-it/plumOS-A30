+
+static Bounds PlumOSRotateUIBounds(const Bounds &bounds, const Bounds &screenBounds) {
+	switch (PlumOSUIRotation()) {
+	case DisplayRotation::ROTATE_90:
+		return Bounds(bounds.y, screenBounds.w - bounds.x2(), bounds.h, bounds.w);
+	case DisplayRotation::ROTATE_270:
+		return Bounds(screenBounds.h - bounds.y2(), bounds.x, bounds.h, bounds.w);
+	case DisplayRotation::ROTATE_180:
+		return Bounds(screenBounds.w - bounds.x2(), screenBounds.h - bounds.y2(), bounds.w, bounds.h);
+	case DisplayRotation::ROTATE_0:
+	default:
+		return bounds;
+	}
+}
