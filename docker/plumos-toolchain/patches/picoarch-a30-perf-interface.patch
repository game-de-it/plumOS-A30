+static retro_time_t pa_perf_get_time_usec(void)
+{
+	struct timeval tv;
+
+	if (gettimeofday(&tv, NULL) != 0)
+		return 0;
+	return (retro_time_t)tv.tv_sec * 1000000 + tv.tv_usec;
+}
+
+static retro_perf_tick_t pa_perf_get_counter(void)
+{
+	return (retro_perf_tick_t)pa_perf_get_time_usec();
+}
+
+static uint64_t pa_perf_get_cpu_features(void)
+{
+	return RETRO_SIMD_NEON | RETRO_SIMD_VFPV3 | RETRO_SIMD_VFPV4;
+}
+
+static void pa_perf_register(struct retro_perf_counter *counter)
+{
+	if (counter)
+		counter->registered = true;
+}
+
+static void pa_perf_start(struct retro_perf_counter *counter)
+{
+	if (!counter)
+		return;
+	if (!counter->registered)
+		pa_perf_register(counter);
+	counter->start = pa_perf_get_counter();
+}
+
+static void pa_perf_stop(struct retro_perf_counter *counter)
+{
+	retro_perf_tick_t now;
+
+	if (!counter || !counter->start)
+		return;
+	now = pa_perf_get_counter();
+	if (now >= counter->start)
+		counter->total += now - counter->start;
+	counter->call_cnt++;
+	counter->start = 0;
+}
+
+static void pa_perf_log(void) {}
