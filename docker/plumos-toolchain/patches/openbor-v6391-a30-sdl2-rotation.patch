@@ -43,6 +58,139 @@ int opengl = 0; // OpenGL backend currently in use?
 int nativeWidth, nativeHeight; // monitor resolution used in fullscreen mode
 int brightness = 0;
 
+static int env_enabled(const char *name, int fallback)
+{
+	const char *value = getenv(name);
+	if(!value || !value[0]) return fallback;
+	if(!SDL_strcasecmp(value, "0") ||
+	   !SDL_strcasecmp(value, "no") ||
+	   !SDL_strcasecmp(value, "false") ||
+	   !SDL_strcasecmp(value, "off")) return 0;
+	return 1;
+}
+
+static void init_a30_present_options(void)
+{
+	const char *rotation;
+	const char *scale;
+
+	if(a30_present_inited) return;
+	a30_present_inited = 1;
+
+	rotation = getenv("PLUMOS_A30_OPENBOR_ROTATION");
+	if(rotation && rotation[0])
+	{
+		if(!SDL_strcasecmp(rotation, "cw") || !SDL_strcasecmp(rotation, "90"))
+			a30_present_angle = 90;
+		else if(!SDL_strcasecmp(rotation, "ccw") || !SDL_strcasecmp(rotation, "270"))
+			a30_present_angle = 270;
+		else if(!SDL_strcasecmp(rotation, "180"))
+			a30_present_angle = 180;
+		else
+			a30_present_angle = 0;
+	}
+
+	scale = getenv("PLUMOS_A30_OPENBOR_SCALE");
+	if(scale && scale[0])
+	{
+		if(!SDL_strcasecmp(scale, "stretch"))
+			a30_present_scale = A30_SCALE_STRETCH;
+		else if(!SDL_strcasecmp(scale, "integer"))
+			a30_present_scale = A30_SCALE_INTEGER;
+		else if(!SDL_strcasecmp(scale, "native") || !SDL_strcasecmp(scale, "none"))
+			a30_present_scale = A30_SCALE_NATIVE;
+		else
+			a30_present_scale = A30_SCALE_FIT;
+	}
+
+	a30_force_fullscreen = env_enabled("PLUMOS_A30_OPENBOR_FULLSCREEN", 0);
+}
+
+static int a30_rotation_enabled(void)
+{
+	init_a30_present_options();
+	return a30_present_angle != 0;
+}
+
+static int a30_fullscreen_enabled(void)
+{
+	init_a30_present_options();
+	return a30_force_fullscreen;
+}
+
+static void a30_present_texture(void)
+{
+	SDL_Rect dst;
+	double angle;
+	int tex_w = 0;
+	int tex_h = 0;
+	int out_w = 0;
+	int out_h = 0;
+	int fit_w;
+	int fit_h;
+	int draw_w;
+	int draw_h;
+	float scale;
+
+	init_a30_present_options();
+	if(!a30_present_angle)
+	{
+		SDL_RenderCopy(renderer, texture, NULL, NULL);
+		return;
+	}
+
+	SDL_QueryTexture(texture, NULL, NULL, &tex_w, &tex_h);
+	SDL_GetRendererOutputSize(renderer, &out_w, &out_h);
+	if(tex_w <= 0 || tex_h <= 0 || out_w <= 0 || out_h <= 0)
+	{
+		SDL_RenderCopy(renderer, texture, NULL, NULL);
+		return;
+	}
+
+	if(a30_present_angle == 90 || a30_present_angle == 270)
+	{
+		fit_w = out_h;
+		fit_h = out_w;
+	}
+	else
+	{
+		fit_w = out_w;
+		fit_h = out_h;
+	}
+
+	switch(a30_present_scale)
+	{
+	case A30_SCALE_STRETCH:
+		draw_w = fit_w;
+		draw_h = fit_h;
+		break;
+	case A30_SCALE_NATIVE:
+		draw_w = tex_w;
+		draw_h = tex_h;
+		break;
+	case A30_SCALE_INTEGER:
+		scale = fminf((float)fit_w / (float)tex_w, (float)fit_h / (float)tex_h);
+		if(scale >= 1.0f) scale = floorf(scale);
+		if(scale <= 0.0f) scale = 1.0f;
+		draw_w = (int)((float)tex_w * scale);
+		draw_h = (int)((float)tex_h * scale);
+		break;
+	default:
+		scale = fminf((float)fit_w / (float)tex_w, (float)fit_h / (float)tex_h);
+		if(scale <= 0.0f) scale = 1.0f;
+		draw_w = (int)((float)tex_w * scale);
+		draw_h = (int)((float)tex_h * scale);
+		break;
+	}
+
+	dst.x = (out_w - draw_w) / 2;
+	dst.y = (out_h - draw_h) / 2;
+	dst.w = draw_w;
+	dst.h = draw_h;
+	angle = (double)a30_present_angle;
+	SDL_RenderCopyEx(renderer, texture, NULL, &dst, angle, NULL, SDL_FLIP_NONE);
+}
+
