+	A30_SCALE_FIT = 0,
+	A30_SCALE_STRETCH,
+	A30_SCALE_INTEGER,
+	A30_SCALE_NATIVE
+};
+
+static int a30_present_inited = 0;
+static int a30_present_angle = 0;
+static int a30_present_scale = A30_SCALE_FIT;
