+	g_a30.gl.TexImage2D(GL_TEXTURE_2D, 0, GL_RGB, width, height, 0,
+			    GL_RGB, GL_UNSIGNED_SHORT_5_6_5, NULL);
+	*texture_w = width;
+	*texture_h = height;
+}
+
+static void compute_integer_rect(int width, int height, int *x, int *y, int *w, int *h)
+{
+	int sx = width > 0 ? g_a30.logical_w / width : 1;
+	int sy = height > 0 ? g_a30.logical_h / height : 1;
+	int scale = sx < sy ? sx : sy;
+
+	if (scale < 1)
+		scale = 1;
+	*w = width * scale;
+	*h = height * scale;
+	if (*w > g_a30.logical_w)
+		*w = g_a30.logical_w;
+	if (*h > g_a30.logical_h)
+		*h = g_a30.logical_h;
+	*x = (g_a30.logical_w - *w) / 2;
+	*y = (g_a30.logical_h - *h) / 2;
+}
