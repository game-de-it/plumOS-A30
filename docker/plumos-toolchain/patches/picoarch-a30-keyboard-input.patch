 static struct retro_disk_control_ext_callback disk_control_ext;
 
 static uint32_t buttons = 0;
+static struct retro_keyboard_callback keyboard_cb;
+static bool keyboard_state(unsigned key)
+{
+	switch (key) {
+	case RETROK_UP:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_UP) & 1;
+	case RETROK_DOWN:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_DOWN) & 1;
+	case RETROK_LEFT:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_LEFT) & 1;
+	case RETROK_RIGHT:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_RIGHT) & 1;
+	case RETROK_SPACE:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_A) & 1;
+	case RETROK_LCTRL:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_B) & 1;
+	case RETROK_LSHIFT:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_X) & 1;
+	case RETROK_LALT:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_Y) & 1;
+	case RETROK_RETURN:
+	case RETROK_KP_ENTER:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_START) & 1;
+	case RETROK_ESCAPE:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_SELECT) & 1;
+	case RETROK_TAB:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_L) & 1;
+	case RETROK_BACKSPACE:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_R) & 1;
+	case RETROK_e:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_L2) & 1;
+	case RETROK_t:
+		return (buttons >> RETRO_DEVICE_ID_JOYPAD_R2) & 1;
+	default:
+		return false;
+	}
+}
+
+static void keyboard_notify(bool down, unsigned key)
+{
+	if (keyboard_cb.callback)
+		keyboard_cb.callback(down, key, 0, 0);
+}
+
+static void keyboard_notify_button(uint32_t old_buttons, uint32_t new_buttons,
+	unsigned button, unsigned key)
+{
+	uint32_t mask = 1U << button;
+	bool was_down = (old_buttons & mask) != 0;
+	bool is_down = (new_buttons & mask) != 0;
+
+	if (was_down != is_down)
+		keyboard_notify(is_down, key);
+}
+
+static void keyboard_update(uint32_t old_buttons, uint32_t new_buttons)
+{
+	if (!keyboard_cb.callback || old_buttons == new_buttons)
+		return;
+
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_UP, RETROK_UP);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_DOWN, RETROK_DOWN);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_LEFT, RETROK_LEFT);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_RIGHT, RETROK_RIGHT);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_A, RETROK_SPACE);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_B, RETROK_LCTRL);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_X, RETROK_LSHIFT);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_Y, RETROK_LALT);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_START, RETROK_RETURN);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_SELECT, RETROK_ESCAPE);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_L, RETROK_TAB);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_R, RETROK_BACKSPACE);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_L2, RETROK_e);
+	keyboard_notify_button(old_buttons, new_buttons, RETRO_DEVICE_ID_JOYPAD_R2, RETROK_t);
+}
 
