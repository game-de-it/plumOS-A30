+
+static int plumos_a30_rotate_ccw(void)
+{
+  const char *value = getenv("PLUMOS_A30_PCSX_ROTATION");
+  return value != NULL && value[0] == 'c' && value[1] == 'c';
+}
+
+static uint32_t plumos_bgr555_to_xrgb8888(uint16_t p)
+{
+  uint32_t t = ((p << 19) | (p >> 7)) & 0xf800f8;
+  t |= (p << 6) & 0xf800;
+  return 0xff000000 | t | ((t >> 5) & 0x070707);
+}
+
+static uint32_t plumos_bgr888_to_xrgb8888(const uint8_t *src)
+{
+  return 0xff000000 | (src[0] << 16) | (src[1] << 8) | src[2];
+}
+
+static uint32_t plumos_rgb565_to_xrgb8888(uint16_t p)
+{
+  uint32_t r = (p >> 11) & 0x1f;
+  uint32_t g = (p >> 5) & 0x3f;
+  uint32_t b = p & 0x1f;
+  r = (r << 3) | (r >> 2);
+  g = (g << 2) | (g >> 4);
+  b = (b << 3) | (b >> 2);
+  return 0xff000000 | (r << 16) | (g << 8) | b;
+}
+
+static void plumos_a30_blit_rotated_xrgb8888(const void *src_, int w, int h,
+    int sstride, int bgr24)
+{
+  uint32_t *dst = plat_sdl_screen->pixels;
+  int dpitch = plat_sdl_screen->pitch / 4;
+  int scale = (w * 2 <= plat_sdl_screen->h && h * 2 <= plat_sdl_screen->w) ? 2 : 1;
+  int logical_w = w * scale;
+  int logical_h = h * scale;
+  int out_w = logical_h;
+  int out_h = logical_w;
+  int ox = (plat_sdl_screen->w - out_w) / 2;
+  int oy = (plat_sdl_screen->h - out_h) / 2;
+  int ccw = plumos_a30_rotate_ccw();
+  int sx, sy, dx, dy;
+
+  if (ox < 0 || oy < 0)
+    return;
+  if (out_w != plat_sdl_screen->w || out_h != plat_sdl_screen->h) {
+    for (dy = 0; dy < plat_sdl_screen->h; dy++)
+      memset(dst + dy * dpitch, 0, plat_sdl_screen->w * 4);
+  }
+
+  for (sy = 0; sy < h; sy++) {
+    const uint16_t *src16 = (const uint16_t *)src_ + sy * sstride;
+    const uint8_t *src24 = (const uint8_t *)src_ + sy * sstride * 2;
+    for (sx = 0; sx < w; sx++) {
+      uint32_t p = bgr24
+        ? plumos_bgr888_to_xrgb8888(src24 + sx * 3)
+        : plumos_bgr555_to_xrgb8888(src16[sx]);
+      for (dy = 0; dy < scale; dy++) {
+        int ly = sy * scale + dy;
+        for (dx = 0; dx < scale; dx++) {
+          int lx = sx * scale + dx;
+          int px = ccw ? ly : logical_h - 1 - ly;
+          int py = ccw ? logical_w - 1 - lx : lx;
+          dst[(oy + py) * dpitch + ox + px] = p;
+        }
+      }
+    }
+  }
+}
+
+static void plumos_a30_blit_menu_rotated_xrgb8888(void)
+{
+  const uint16_t *src = g_menuscreen_ptr;
+  uint32_t *dst = plat_sdl_screen->pixels;
+  int dpitch = plat_sdl_screen->pitch / 4;
+  int logical_w = g_menuscreen_w;
+  int logical_h = g_menuscreen_h;
+  int out_w = logical_h;
+  int out_h = logical_w;
+  int ox = (plat_sdl_screen->w - out_w) / 2;
+  int oy = (plat_sdl_screen->h - out_h) / 2;
+  int ccw = plumos_a30_rotate_ccw();
+  int x, y;
+
+  if (ox < 0 || oy < 0)
+    return;
+  for (y = 0; y < plat_sdl_screen->h; y++)
+    memset(dst + y * dpitch, 0, plat_sdl_screen->w * 4);
+
+  for (y = 0; y < g_menuscreen_h; y++) {
+    const uint16_t *row = src + y * g_menuscreen_pp;
+    for (x = 0; x < g_menuscreen_w; x++) {
+      int px = ccw ? y : logical_h - 1 - y;
+      int py = ccw ? logical_w - 1 - x : x;
+      dst[(oy + py) * dpitch + ox + px] = plumos_rgb565_to_xrgb8888(row[x]);
+    }
+  }
+}
+
+static void plumos_a30_blit_rgb565_rotated_xrgb8888(const uint16_t *src,
+    int w, int h, int spitch)
+{
+  uint32_t *dst = plat_sdl_screen->pixels;
+  int dpitch = plat_sdl_screen->pitch / 4;
+  int scale = (w * 2 <= plat_sdl_screen->h && h * 2 <= plat_sdl_screen->w) ? 2 : 1;
+  int logical_w = w * scale;
+  int logical_h = h * scale;
+  int out_w = logical_h;
+  int out_h = logical_w;
+  int ox = (plat_sdl_screen->w - out_w) / 2;
+  int oy = (plat_sdl_screen->h - out_h) / 2;
+  int ccw = plumos_a30_rotate_ccw();
+  int sx, sy, dx, dy;
+
+  if (ox < 0 || oy < 0)
+    return;
+  if (out_w != plat_sdl_screen->w || out_h != plat_sdl_screen->h) {
+    for (dy = 0; dy < plat_sdl_screen->h; dy++)
+      memset(dst + dy * dpitch, 0, plat_sdl_screen->w * 4);
+  }
+
+  for (sy = 0; sy < h; sy++) {
+    const uint16_t *row = src + sy * spitch;
+    for (sx = 0; sx < w; sx++) {
+      uint32_t p = plumos_rgb565_to_xrgb8888(row[sx]);
+      for (dy = 0; dy < scale; dy++) {
+        int ly = sy * scale + dy;
+        for (dx = 0; dx < scale; dx++) {
+          int lx = sx * scale + dx;
+          int px = ccw ? ly : logical_h - 1 - ly;
+          int py = ccw ? logical_w - 1 - lx : lx;
+          dst[(oy + py) * dpitch + ox + px] = p;
+        }
+      }
+    }
+  }
 }
 
