diff --git a/src/screen.cpp b/src/screen.cpp
index 43d31fa..268d4f0 100644
--- a/src/screen.cpp
+++ b/src/screen.cpp
@@ -32,6 +32,52 @@ SDL_Surface *SetVideoMode(int width, int height, int bpp, std::uint32_t flags)
 
 }
 
+#if defined(USE_SDL2) && defined(A30_ROTATE_SURFACE)
+void A30RotateWindowSurface(SDL_Window *window, SDL_Surface *src)
+{
+    SDL_Surface *dst = SDL_GetWindowSurface(window);
+    if (dst == nullptr || src == nullptr) {
+        return;
+    }
+    if (src->format->BytesPerPixel != 4 || dst->format->BytesPerPixel != 4) {
+        SDL_Log("A30RotateWindowSurface requires 32bpp surfaces: src=%d dst=%d",
+            src->format->BytesPerPixel * 8, dst->format->BytesPerPixel * 8);
+        return;
+    }
+
+    SDL_FillRect(dst, nullptr, 0);
+
+    const bool lock_src = SDL_MUSTLOCK(src);
+    const bool lock_dst = SDL_MUSTLOCK(dst);
+    if (lock_src && SDL_LockSurface(src) != 0) {
+        SDL_Log("SDL_LockSurface(src) failed: %s", SDL_GetError());
+        return;
+    }
+    if (lock_dst && SDL_LockSurface(dst) != 0) {
+        if (lock_src) SDL_UnlockSurface(src);
+        SDL_Log("SDL_LockSurface(dst) failed: %s", SDL_GetError());
+        return;
+    }
+
+    for (int y = 0; y < src->h; ++y) {
+        const auto *src_row = reinterpret_cast<const std::uint32_t *>(
+            static_cast<const std::uint8_t *>(src->pixels) + y * src->pitch);
+        for (int x = 0; x < src->w; ++x) {
+            const int dx = y;
+            const int dy = dst->h - 1 - x;
+            if (dx < 0 || dx >= dst->w || dy < 0 || dy >= dst->h) continue;
+            auto *dst_row = reinterpret_cast<std::uint32_t *>(
+                static_cast<std::uint8_t *>(dst->pixels) + dy * dst->pitch);
+            dst_row[dx] = src_row[x];
+        }
+    }
+
+    if (lock_dst) SDL_UnlockSurface(dst);
+    if (lock_src) SDL_UnlockSurface(src);
+    SDL_UpdateWindowSurface(window);
+}
+#endif
+
 int Screen::init()
 {
     const auto &cfg = config();
