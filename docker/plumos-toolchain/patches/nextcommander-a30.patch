+
+# Miyoo A30 / plumOS
+else ifneq (,$(findstring a30,$(PLATFORM)))
+SDCARD_ROOT := /mnt/SDCARD
+NEXTUI_SYSTEM_PATH := $(SDCARD_ROOT)/plumos/apps/nextcommander
+
+CXXFLAGS += -O2 -pipe -marm -march=armv7-a -mtune=cortex-a7 -mfpu=neon-vfpv4 -mfloat-abi=hard -fomit-frame-pointer
+CXXFLAGS += -DPATH_DEFAULT=\"$(SDCARD_ROOT)\"
+CXXFLAGS += -DPATH_DEFAULT_RIGHT=\"$(SDCARD_ROOT)/plumos\"
+CXXFLAGS += -DFILE_SYSTEM=\"$(SDCARD_ROOT)\"
+
+# Buttons from plumOS joystickd --device-mode xbox:
+# A/B/X/Y = 0/1/2/3, L/R = 4/5, SELECT/START/FUNCTION = 8/9/10.
+CXXFLAGS += -DCMDR_KEY_UP=SDLK_UP
+CXXFLAGS += -DCMDR_KEY_RIGHT=SDLK_RIGHT
+CXXFLAGS += -DCMDR_KEY_DOWN=SDLK_DOWN
+CXXFLAGS += -DCMDR_KEY_LEFT=SDLK_LEFT
+CXXFLAGS += -DCMDR_KEY_OPEN=0
+CXXFLAGS += -DCMDR_KEY_PARENT=1
+CXXFLAGS += -DCMDR_KEY_OPERATION=2
+CXXFLAGS += -DCMDR_KEY_SYSTEM=3
+CXXFLAGS += -DCMDR_KEY_PAGEUP=4
+CXXFLAGS += -DCMDR_KEY_PAGEDOWN=5
+CXXFLAGS += -DCMDR_KEY_SELECT=8
+CXXFLAGS += -DCMDR_KEY_TRANSFER=9
+CXXFLAGS += -DCMDR_KEY_MENU=10
+CXXFLAGS += -DIGNORE_KEYDOWN=1
+
+CXXFLAGS += -DAUTOSCALE=0
+CXXFLAGS += -DAUTOSCALE_DPI=0
+CXXFLAGS += -DPPU_X=2
+CXXFLAGS += -DPPU_Y=2
+CXXFLAGS += -DSCREEN_BPP=32
+CXXFLAGS += -DA30_ROTATE_SURFACE=1
 endif
 
