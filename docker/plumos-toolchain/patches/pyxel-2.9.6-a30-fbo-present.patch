+struct A30Present {
+    logical_width: u32,
+    logical_height: u32,
+    physical_width: u32,
+    physical_height: u32,
+    framebuffer: glow::NativeFramebuffer,
+    texture: glow::NativeTexture,
+    program: glow::NativeProgram,
+    vertex_array: glow::NativeVertexArray,
+    _vertex_buffer: glow::NativeBuffer,
