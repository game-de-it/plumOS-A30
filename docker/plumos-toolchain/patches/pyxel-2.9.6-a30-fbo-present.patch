+
+impl A30Present {
+    unsafe fn new(
+        gl: &mut Context,
+        logical_width: u32,
+        logical_height: u32,
+        physical_width: u32,
+        physical_height: u32,
+        rotation: &str,
+    ) -> Self {
+        let texture = gl
+            .create_texture()
+            .expect("Failed to create A30 present texture");
+        gl.bind_texture(glow::TEXTURE_2D, Some(texture));
+        gl.tex_parameter_i32(
+            glow::TEXTURE_2D,
+            glow::TEXTURE_MIN_FILTER,
+            glow::LINEAR as i32,
+        );
+        gl.tex_parameter_i32(
+            glow::TEXTURE_2D,
+            glow::TEXTURE_MAG_FILTER,
+            glow::LINEAR as i32,
+        );
+        gl.tex_parameter_i32(
+            glow::TEXTURE_2D,
+            glow::TEXTURE_WRAP_S,
+            glow::CLAMP_TO_EDGE as i32,
+        );
+        gl.tex_parameter_i32(
+            glow::TEXTURE_2D,
+            glow::TEXTURE_WRAP_T,
+            glow::CLAMP_TO_EDGE as i32,
+        );
+        gl.tex_image_2d(
+            glow::TEXTURE_2D,
+            0,
+            glow::RGBA as i32,
+            logical_width as i32,
+            logical_height as i32,
+            0,
+            glow::RGBA,
+            glow::UNSIGNED_BYTE,
+            PixelUnpackData::Slice(None),
+        );
+
+        let framebuffer = gl
+            .create_framebuffer()
+            .expect("Failed to create A30 present framebuffer");
+        gl.bind_framebuffer(glow::FRAMEBUFFER, Some(framebuffer));
+        gl.framebuffer_texture_2d(
+            glow::FRAMEBUFFER,
+            glow::COLOR_ATTACHMENT0,
+            glow::TEXTURE_2D,
+            Some(texture),
+            0,
+        );
+        assert_eq!(
+            gl.check_framebuffer_status(glow::FRAMEBUFFER),
+            glow::FRAMEBUFFER_COMPLETE,
+            "A30 present framebuffer is incomplete"
+        );
+        gl.bind_framebuffer(glow::FRAMEBUFFER, None);
+
+        let program = Self::create_program(gl);
+        let vertex_array = gl
+            .create_vertex_array()
+            .expect("Failed to create A30 present vertex array");
+        let vertex_buffer = gl
+            .create_buffer()
+            .expect("Failed to create A30 present vertex buffer");
+        let vertices = Self::vertices(
+            rotation,
+            logical_width,
+            logical_height,
+            physical_width,
+            physical_height,
+        );
+
+        gl.bind_vertex_array(Some(vertex_array));
+        gl.bind_buffer(glow::ARRAY_BUFFER, Some(vertex_buffer));
+        gl.buffer_data_u8_slice(
+            glow::ARRAY_BUFFER,
+            vertices.align_to::<u8>().1,
+            glow::STATIC_DRAW,
+        );
+
+        let position = gl
+            .get_attrib_location(program, "position")
+            .expect("Failed to find A30 present attribute 'position'");
+        gl.vertex_attrib_pointer_f32(
+            position,
+            2,
+            glow::FLOAT,
+            false,
+            4 * std::mem::size_of::<f32>() as i32,
+            0,
+        );
+        gl.enable_vertex_attrib_array(position);
+
+        let tex_coord = gl
+            .get_attrib_location(program, "texCoord")
+            .expect("Failed to find A30 present attribute 'texCoord'");
+        gl.vertex_attrib_pointer_f32(
+            tex_coord,
+            2,
+            glow::FLOAT,
+            false,
+            4 * std::mem::size_of::<f32>() as i32,
+            2 * std::mem::size_of::<f32>() as i32,
+        );
+        gl.enable_vertex_attrib_array(tex_coord);
+
+        Self {
+            logical_width,
+            logical_height,
+            physical_width,
+            physical_height,
+            framebuffer,
+            texture,
+            program,
+            vertex_array,
+            _vertex_buffer: vertex_buffer,
+        }
+    }
+
+    unsafe fn create_program(gl: &mut Context) -> glow::NativeProgram {
+        let vertex_shader = gl
+            .create_shader(glow::VERTEX_SHADER)
+            .expect("Failed to create A30 present vertex shader");
+        gl.shader_source(vertex_shader, A30_PRESENT_VERT);
+        gl.compile_shader(vertex_shader);
+        assert!(
+            gl.get_shader_compile_status(vertex_shader),
+            "{}",
+            gl.get_shader_info_log(vertex_shader)
+        );
+
+        let fragment_shader = gl
+            .create_shader(glow::FRAGMENT_SHADER)
+            .expect("Failed to create A30 present fragment shader");
+        gl.shader_source(fragment_shader, A30_PRESENT_FRAG);
+        gl.compile_shader(fragment_shader);
+        assert!(
+            gl.get_shader_compile_status(fragment_shader),
+            "{}",
+            gl.get_shader_info_log(fragment_shader)
+        );
+
+        let program = gl
+            .create_program()
+            .expect("Failed to create A30 present shader program");
+        gl.attach_shader(program, vertex_shader);
+        gl.attach_shader(program, fragment_shader);
+        gl.link_program(program);
+        assert!(
+            gl.get_program_link_status(program),
+            "{}",
+            gl.get_program_info_log(program)
+        );
+        gl.detach_shader(program, vertex_shader);
+        gl.detach_shader(program, fragment_shader);
+        gl.delete_shader(vertex_shader);
+        gl.delete_shader(fragment_shader);
+        program
+    }
+
+    fn fit_extents(
+        rotation: &str,
+        logical_width: u32,
+        logical_height: u32,
+        physical_width: u32,
+        physical_height: u32,
+    ) -> (f32, f32) {
+        let (display_width, display_height) = match rotation {
+            "none" => (physical_width as f32, physical_height as f32),
+            _ => (physical_height as f32, physical_width as f32),
+        };
+        let scale = (display_width / logical_width as f32)
+            .min(display_height / logical_height as f32)
+            .min(1.0);
+        let output_width = logical_width as f32 * scale;
+        let output_height = logical_height as f32 * scale;
+        match rotation {
+            "none" => (output_width / display_width, output_height / display_height),
+            _ => (output_height / physical_width as f32, output_width / physical_height as f32),
+        }
+    }
+
+    fn vertices(
+        rotation: &str,
+        logical_width: u32,
+        logical_height: u32,
+        physical_width: u32,
+        physical_height: u32,
+    ) -> [f32; 16] {
+        let (x, y) = Self::fit_extents(
+            rotation,
+            logical_width,
+            logical_height,
+            physical_width,
+            physical_height,
+        );
+        match rotation {
+            "cw" => [
+                -x, -y, 0.0, 1.0, -x, y, 1.0, 1.0, x, -y, 0.0, 0.0, x, y, 1.0,
+                0.0,
+            ],
+            "none" => [
+                -x, -y, 0.0, 0.0, -x, y, 0.0, 1.0, x, -y, 1.0, 0.0, x, y, 1.0,
+                1.0,
+            ],
+            _ => [
+                -x, -y, 1.0, 0.0, -x, y, 0.0, 0.0, x, -y, 1.0, 1.0, x, y, 0.0,
+                1.0,
+            ],
+        }
+    }
+}
