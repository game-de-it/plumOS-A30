+static int plumos_a30_zoom_coord(int v, int center, int num, int den)
+{
+  int off = v - center;
+  if (off >= 0)
+    return center + (off * den + num / 2) / num;
+  return center - ((-off * den + num / 2) / num);
+}
+
+static void plumos_a30_menu_zoom_ratio(int *num, int *den)
+{
+  const char *value = getenv("PLUMOS_A30_PCSX_MENU_ZOOM");
+  long n, d = 1;
+  char *end;
+
+  *num = 1;
+  *den = 1;
+
+  if (value == NULL || value[0] == '\0')
+    return;
+  if (value[0] == '0' || value[0] == 'n' || value[0] == 'N'
+      || value[0] == 'f' || value[0] == 'F') {
+    *num = 1;
+    *den = 1;
+    return;
   }
+
+  n = strtol(value, &end, 10);
+  if (end != NULL && *end == '/') {
+    const char *den_start = end + 1;
+    d = strtol(den_start, &end, 10);
+  }
+
+  if (n >= d && d > 0 && n <= d * 2) {
+    *num = (int)n;
+    *den = (int)d;
+  }
 }
 
+static int plumos_a30_menu_edge_mask(void)
+{
+  const char *value = getenv("PLUMOS_A30_PCSX_MENU_EDGE_MASK");
+  int pixels;
+
+  if (value == NULL || value[0] == '\0')
+    return 0;
+  pixels = atoi(value);
+  if (pixels < 0)
+    return 0;
+  if (pixels > 64)
+    return 64;
+  return pixels;
+}
