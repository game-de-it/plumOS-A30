#!/bin/sh
set -u

if [ "${PLUMOS_STOCK_SERVICES_STAGED:-0}" != "1" ]; then
  case "${1:-}" in
    boot|normalize-sdcard)
      STAGED_HELPER="${PLUMOS_STOCK_SERVICES_STAGE:-/tmp/plumos-stock-services.run}"
      if cp "$0" "$STAGED_HELPER" 2>/dev/null; then
        chmod 755 "$STAGED_HELPER" 2>/dev/null || true
        cd / 2>/dev/null || true
        export PLUMOS_STOCK_SERVICES_STAGED=1
        exec "$STAGED_HELPER" "$@"
      fi
      ;;
  esac
fi
cd / 2>/dev/null || true

PLUMOS_ROOT="${PLUMOS_ROOT:-/mnt/SDCARD/plumos}"
SDCARD_ROOT="${PLUMOS_SDCARD_ROOT:-/mnt/SDCARD}"
SD_DEVICE="${PLUMOS_SDCARD_DEVICE:-/dev/mmcblk0p1}"
SDCARD_MOUNT_OPTS="${PLUMOS_SDCARD_MOUNT_OPTS:-rw,utf8=1,shortname=mixed,fmask=0022,dmask=0022}"
LOG_DIR="${PLUMOS_ROOT}/logs"
LOG_FILE="${LOG_DIR}/stock-services.log"
TMP_LOG_FILE="${PLUMOS_STOCK_SERVICES_TMP_LOG:-/tmp/plumos-stock-services.log}"
NTP_PID_FILE="${PLUMOS_NTP_PID_FILE:-/tmp/plumos-ntpd.pid}"
NTPD="${PLUMOS_NTPD:-/usr/sbin/ntpd}"
NTP_SERVERS="${PLUMOS_NTP_SERVERS:-time.cloudflare.com pool.ntp.org time.google.com time.apple.com}"

mkdir -p "$LOG_DIR" 2>/dev/null || true

uptime_now() {
  if [ -r /proc/uptime ]; then
    read -r up _ < /proc/uptime || up=unknown
    printf '%s' "$up"
  else
    printf '%s' "unknown"
  fi
}

log() {
  line="$(printf '%s uptime=%s %s' "$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo unknown-time)" "$(uptime_now)" "$*")"
  printf '%s\n' "$line" >> "$TMP_LOG_FILE" 2>/dev/null || true
  printf '%s\n' "$line" >> "$LOG_FILE" 2>/dev/null || true
}

cmdline_for_pid() {
  cat "/proc/$1/cmdline" 2>/dev/null | tr '\0' ' ' || true
}

cmd_matches() {
  cmd="$1"
  shift
  for pattern in "$@"; do
    case "$cmd" in
      $pattern) return 0 ;;
    esac
  done
  return 1
}

find_pids_by_cmd() {
  self="$$"
  for proc in /proc/[0-9]*; do
    pid="${proc#/proc/}"
    case "$pid" in
      *[!0-9]*|'') continue ;;
    esac
    [ "$pid" = "$self" ] && continue
    cmd="$(cmdline_for_pid "$pid")"
    [ -n "$cmd" ] || continue
    if cmd_matches "$cmd" "$@"; then
      printf '%s\n' "$pid"
    fi
  done
}

terminate_pids() {
  label="$1"
  shift
  [ "$#" -gt 0 ] || {
    log "${label}: no matching process"
    return 0
  }
  log "${label}: stopping pids=$*"
  kill -TERM "$@" 2>/dev/null || true
  sleep 1
  kill -KILL "$@" 2>/dev/null || true
}

stop_init_script() {
  script="$1"
  if [ -x "$script" ]; then
    log "init stop ${script}"
    "$script" stop >/dev/null 2>&1 || true
  fi
}

stop_stock_usb_userland() {
  pids=""
  log "stop stock USB userland begin"
  stop_init_script /etc/init.d/mtp
  stop_init_script /etc/init.d/adbd
  for pid in $(find_pids_by_cmd '*/usr/sbin/MtpDaemon*' '*/bin/adbd*'); do
    pids="${pids} ${pid}"
  done
  # shellcheck disable=SC2086
  terminate_pids "stock USB userland" $pids
  log "stop stock USB userland end"
}

stop_stock_keymon() {
  pids=""
  for pid in $(find_pids_by_cmd '*/miyoo*/app/keymon*' '*/app/keymon*'); do
    pids="${pids} ${pid}"
  done
  # shellcheck disable=SC2086
  terminate_pids "stock keymon" $pids
}

sdcard_mount_line() {
  awk -v mp="$SDCARD_ROOT" '$2 == mp { print; exit }' /proc/mounts 2>/dev/null || true
}

sdcard_mount_needs_utf8_fix() {
  line="$(sdcard_mount_line)"
  case "$line" in
    *" vfat "*)
      case "$line" in
        *utf8=0*) return 0 ;;
        *utf8=1*|*,utf8,*|*,utf8\ *|*iocharset=utf8*) return 1 ;;
        *iocharset=ascii*) return 0 ;;
      esac
      ;;
  esac
  return 1
}

invalidate_frontend_system_cache() {
  cache_dir="${PLUMOS_ROOT}/state/frontend/systems"
  [ -d "$cache_dir" ] || return 0
  rm -f "$cache_dir"/*.json 2>/dev/null || true
  log "invalidated frontend per-system ROM cache: ${cache_dir}"
}

mount_sdcard_utf8() {
  mkdir -p "$SDCARD_ROOT" 2>/dev/null || true
  err="/tmp/plumos-stock-services-mount.err"
  for opts in \
    "$SDCARD_MOUNT_OPTS" \
    "rw,utf8,shortname=mixed,fmask=0022,dmask=0022" \
    "rw,iocharset=utf8,shortname=mixed,fmask=0022,dmask=0022"; do
    if mount -t vfat -o "$opts" "$SD_DEVICE" "$SDCARD_ROOT" 2>"$err"; then
      rm -f "$err" 2>/dev/null || true
      log "mounted ${SD_DEVICE} on ${SDCARD_ROOT} options=${opts}"
      return 0
    fi
    if [ -s "$err" ]; then
      while IFS= read line; do
        log "mount options=${opts}: ${line}"
      done < "$err"
    fi
  done
  rm -f "$err" 2>/dev/null || true

  if mount "$SDCARD_ROOT" 2>/dev/null || mount "$SD_DEVICE" "$SDCARD_ROOT" 2>/dev/null; then
    log "mounted ${SD_DEVICE} on ${SDCARD_ROOT} using default mount fallback"
    return 0
  fi
  log "failed to mount ${SD_DEVICE} on ${SDCARD_ROOT}"
  return 1
}

normalize_sdcard_mount() {
  line="$(sdcard_mount_line)"
  if [ -z "$line" ]; then
    log "SD card is not mounted; mounting with UTF-8 options"
    mount_sdcard_utf8 || return 1
    if sdcard_mount_needs_utf8_fix; then
      log "SD card mount still needs UTF-8 fix after mount: $(sdcard_mount_line)"
      return 1
    fi
    invalidate_frontend_system_cache
    return 0
  fi

  if ! sdcard_mount_needs_utf8_fix; then
    log "SD card mount is already non-ascii: ${line}"
    return 0
  fi

  log "SD card mount uses ASCII filename conversion; remounting: ${line}"
  stop_stock_keymon
  sync

  err="/tmp/plumos-stock-services-umount.err"
  if ! umount "$SDCARD_ROOT" 2>"$err"; then
    log "SD card UTF-8 normalization skipped; unmount failed"
    if [ -s "$err" ]; then
      while IFS= read line; do
        log "umount ${SDCARD_ROOT}: ${line}"
      done < "$err"
    fi
    rm -f "$err" 2>/dev/null || true
    return 1
  fi
  rm -f "$err" 2>/dev/null || true

  if ! mount_sdcard_utf8; then
    log "SD card UTF-8 remount failed"
    return 1
  fi

  line="$(sdcard_mount_line)"
  if sdcard_mount_needs_utf8_fix; then
    log "SD card mount is still ASCII after remount: ${line}"
    return 1
  fi

  log "SD card UTF-8 normalization complete: ${line}"
  invalidate_frontend_system_cache
}

ntp_pid_running() {
  [ -r "$NTP_PID_FILE" ] || return 1
  read -r pid < "$NTP_PID_FILE" || return 1
  case "$pid" in
    *[!0-9]*|'') return 1 ;;
  esac
  kill -0 "$pid" 2>/dev/null || return 1
  cmd="$(cmdline_for_pid "$pid")"
  case "$cmd" in
    *ntpd*) return 0 ;;
  esac
  return 1
}

stop_all_ntp() {
  pids=""
  log "stop NTP begin"
  stop_init_script /etc/init.d/sysntpd
  stop_init_script /etc/init.d/ntpd
  for pid in $(find_pids_by_cmd '*/usr/sbin/ntpd*' '* busybox ntpd *' '* ntpd -n*' '* ntpd -N*'); do
    pids="${pids} ${pid}"
  done
  # shellcheck disable=SC2086
  terminate_pids "NTP" $pids
  rm -f "$NTP_PID_FILE" 2>/dev/null || true
  log "stop NTP end"
}

start_plumos_ntp() {
  if ntp_pid_running; then
    read -r pid < "$NTP_PID_FILE" || pid=unknown
    log "plumOS NTP already running pid=${pid}"
    return 0
  fi
  if [ ! -x "$NTPD" ]; then
    log "plumOS NTP backend missing: ${NTPD}"
    return 1
  fi

  stop_all_ntp
  set -- -n -N
  for server in $NTP_SERVERS; do
    set -- "$@" -p "$server"
  done
  log "starting plumOS NTP: ${NTPD} servers=${NTP_SERVERS}"
  "$NTPD" "$@" >> "$LOG_FILE" 2>&1 &
  pid="$!"
  printf '%s\n' "$pid" > "$NTP_PID_FILE" 2>/dev/null || true
  log "plumOS NTP started pid=${pid}"
}

network_ready() {
  stop_stock_usb_userland
  start_plumos_ntp
}

boot_normalize() {
  stop_stock_usb_userland
  stop_all_ntp
  normalize_sdcard_mount || true
}

status() {
  printf 'sdcard_mount=%s\n' "$(sdcard_mount_line)"
  printf 'stock_usb_pids='
  find_pids_by_cmd '*/usr/sbin/MtpDaemon*' '*/bin/adbd*' | tr '\n' ' '
  printf '\n'
  printf 'ntp_pids='
  find_pids_by_cmd '*/usr/sbin/ntpd*' '* busybox ntpd *' '* ntpd -n*' '* ntpd -N*' | tr '\n' ' '
  printf '\n'
  if ntp_pid_running; then
    read -r pid < "$NTP_PID_FILE" || pid=unknown
    printf 'plumos_ntp=running pid=%s\n' "$pid"
  else
    printf 'plumos_ntp=stopped\n'
  fi
}

case "${1:-}" in
  boot)
    boot_normalize
    ;;
  network-ready)
    network_ready
    ;;
  stop-usb)
    stop_stock_usb_userland
    ;;
  normalize-sdcard)
    normalize_sdcard_mount
    ;;
  ntp-start)
    start_plumos_ntp
    ;;
  ntp-stop)
    stop_all_ntp
    ;;
  status)
    status
    ;;
  *)
    cat >&2 <<EOF
Usage: $0 COMMAND

Commands:
  boot           Stop StockOS USB userland and StockOS NTP during plumOS boot.
  network-ready  Keep StockOS USB userland stopped and start plumOS-managed NTP.
  stop-usb       Stop StockOS MtpDaemon/adbd.
  normalize-sdcard
                 Remount /mnt/SDCARD with UTF-8 vfat filename handling when needed.
  ntp-start      Stop StockOS NTP and start plumOS-managed ntpd.
  ntp-stop       Stop all known ntpd instances.
  status         Print StockOS USB and NTP process status.
EOF
    exit 1
    ;;
esac
