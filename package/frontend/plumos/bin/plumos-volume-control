#!/bin/sh
set -u

PLUMOS_ROOT=${PLUMOS_ROOT:-/mnt/SDCARD/plumos}
SYSTEM_SETTINGS=${PLUMOS_SYSTEM_SETTINGS_JSON:-$PLUMOS_ROOT/config/system/settings.json}
LOG=${PLUMOS_VOLUME_LOG:-/tmp/.plumos_volume_set}
SOFTVOL_NAME=${PLUMOS_VOLUME_SOFTVOL_NAME:-Soft Volume Master}
SILENCE_RAW=${PLUMOS_VOLUME_SILENCE_RAW:-/tmp/plumos-volume-silence.raw}

find_cmd() {
  for path in "$@"; do
    if [ -x "$path" ]; then
      printf '%s\n' "$path"
      return 0
    fi
  done
  return 1
}

AMIXER=${PLUMOS_AMIXER:-$(find_cmd /usr/bin/amixer /bin/amixer /sbin/amixer 2>/dev/null || true)}
APLAY=${PLUMOS_APLAY:-$(find_cmd /usr/bin/aplay /bin/aplay /sbin/aplay 2>/dev/null || true)}

usage() {
  cat <<USAGE
Usage: plumos-volume-control init|apply [0..20]|up|down|step +/-N|get|status

Initializes and applies the A30 stock-compatible ALSA softvol control.
USAGE
}

read_volume() {
  value=""
  if [ -r "$SYSTEM_SETTINGS" ]; then
    value="$(sed -n 's/.*"volume"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "$SYSTEM_SETTINGS" 2>/dev/null | head -n 1)"
  fi
  case "$value" in
    ""|*[!0-9]*) value=20 ;;
  esac
  value="$(printf '%s' "$value" | sed 's/^0*//')"
  [ -n "$value" ] || value=0
  if [ "$value" -gt 20 ]; then
    value=20
  fi
  printf '%s\n' "$value"
}

normalize_volume() {
  value=${1:-}
  case "$value" in
    ""|*[!0-9]*) return 1 ;;
  esac
  value="$(printf '%s' "$value" | sed 's/^0*//')"
  [ -n "$value" ] || value=0
  if [ "$value" -gt 20 ]; then
    value=20
  fi
  printf '%s\n' "$value"
}

valid_signed_int() {
  value=${1:-}
  case "$value" in
    -*) value=${value#-} ;;
  esac
  case "$value" in
    ""|*[!0-9]*) return 1 ;;
  esac
  return 0
}

softvol_exists() {
  [ -n "$AMIXER" ] || return 1
  "$AMIXER" cget iface=MIXER,name="$SOFTVOL_NAME" >/dev/null 2>&1
}

init_softvol() {
  [ -n "$AMIXER" ] || {
    echo "amixer not found" >"$LOG"
    return 1
  }
  softvol_exists && return 0
  [ -n "$APLAY" ] || {
    echo "aplay not found and softvol is not initialized" >"$LOG"
    return 1
  }

  dd if=/dev/zero of="$SILENCE_RAW" bs=3840 count=1 >/dev/null 2>&1 || : >"$SILENCE_RAW"
  "$APLAY" -q -D default -f S16_LE -r 48000 -c 2 "$SILENCE_RAW" >>"$LOG" 2>&1 || true
  softvol_exists
}

scale_volume() {
  volume=$1
  printf '%s\n' $(( (volume * 255 + 10) / 20 ))
}

apply_volume() {
  if [ "$#" -gt 0 ]; then
    volume="$(normalize_volume "$1")" || {
      echo "invalid volume: $1" >"$LOG"
      return 2
    }
  else
    volume="$(read_volume)"
  fi
  value="$(scale_volume "$volume")"
  init_softvol || return 1
  "$AMIXER" cset iface=MIXER,name="$SOFTVOL_NAME" "$value" >"$LOG" 2>&1
}

backup_settings_once() {
  [ -r "$SYSTEM_SETTINGS" ] || return 0
  backup_dir="$PLUMOS_ROOT/backups/system"
  backup_path="$backup_dir/settings.json.before-volume-control"
  [ -e "$backup_path" ] && return 0
  mkdir -p "$backup_dir" 2>/dev/null || return 0
  cp -p "$SYSTEM_SETTINGS" "$backup_path" 2>/dev/null || cp "$SYSTEM_SETTINGS" "$backup_path" 2>/dev/null || true
}

write_volume_setting() {
  volume="$(normalize_volume "$1")" || {
    echo "invalid volume: $1" >"$LOG"
    return 2
  }
  settings_dir=${SYSTEM_SETTINGS%/*}
  if [ "$settings_dir" = "$SYSTEM_SETTINGS" ]; then
    settings_dir=.
  fi
  tmp="$SYSTEM_SETTINGS.tmp.$$"

  mkdir -p "$settings_dir" 2>/dev/null || {
    echo "cannot create settings dir: $settings_dir" >"$LOG"
    return 1
  }
  backup_settings_once

  if [ -r "$SYSTEM_SETTINGS" ]; then
    if grep -q '"volume"[[:space:]]*:' "$SYSTEM_SETTINGS" 2>/dev/null; then
      sed 's/"volume"[[:space:]]*:[[:space:]]*[0-9][0-9]*/"volume": '"$volume"'/' \
        "$SYSTEM_SETTINGS" >"$tmp" || {
          rm -f "$tmp"
          echo "cannot update volume in settings" >"$LOG"
          return 1
        }
    else
      awk -v volume="$volume" '
        BEGIN { inserted = 0; pending = "" }
        {
          if (!inserted && $0 ~ /^[[:space:]]*}[[:space:]]*[,]?[[:space:]]*$/) {
            if (pending != "") {
              sub(/[[:space:]]*$/, "", pending)
              if (pending !~ /,[[:space:]]*$/) {
                pending = pending ","
              }
              print pending
              pending = ""
            }
            print "  \"volume\": " volume
            print $0
            inserted = 1
            next
          }
          if (pending != "") {
            print pending
          }
          pending = $0
        }
        END {
          if (pending != "") {
            print pending
          }
          if (!inserted) {
            print "{"
            print "  \"version\": 1,"
            print "  \"volume\": " volume
            print "}"
          }
        }
      ' "$SYSTEM_SETTINGS" >"$tmp" || {
        rm -f "$tmp"
        echo "cannot insert volume in settings" >"$LOG"
        return 1
      }
    fi
  else
    {
      echo "{"
      echo "  \"version\": 1,"
      echo "  \"volume\": $volume"
      echo "}"
    } >"$tmp" || {
      rm -f "$tmp"
      echo "cannot create settings" >"$LOG"
      return 1
    }
  fi

  mv "$tmp" "$SYSTEM_SETTINGS" 2>/dev/null || {
    rm -f "$tmp"
    echo "cannot replace settings" >"$LOG"
    return 1
  }
  sync
  printf '%s\n' "$volume"
}

change_volume() {
  delta=${1:-}
  valid_signed_int "$delta" || {
    echo "invalid volume delta: $delta" >"$LOG"
    return 2
  }
  current="$(read_volume)"
  next=$(( current + delta ))
  if [ "$next" -lt 0 ]; then
    next=0
  elif [ "$next" -gt 20 ]; then
    next=20
  fi
  if [ "$next" = "$current" ]; then
    apply_volume "$next" || return $?
    echo "volume=$next" >"$LOG"
    printf 'volume=%s\n' "$next"
    return 0
  fi
  write_volume_setting "$next" >/dev/null || return $?
  apply_volume "$next" || return $?
  echo "volume=$next" >"$LOG"
  printf 'volume=%s\n' "$next"
}

get_volume() {
  init_softvol || return 1
  "$AMIXER" cget iface=MIXER,name="$SOFTVOL_NAME"
}

case "${1:-status}" in
  init)
    init_softvol
    ;;
  apply|set)
    shift
    apply_volume "$@"
    ;;
  up|increase|plus)
    change_volume 1
    ;;
  down|decrease|minus)
    change_volume -1
    ;;
  step)
    shift
    change_volume "${1:-}"
    ;;
  get|status)
    get_volume
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
