#!/bin/sh
set -u

PLUMOS_ROOT="${PLUMOS_ROOT:-/mnt/SDCARD/plumos}"
PLUMOS_SDCARD_ROOT="${PLUMOS_SDCARD_ROOT:-/mnt/SDCARD}"
ANDROID_USB="${PLUMOS_ANDROID_USB:-/sys/class/android_usb/android0}"
MASS_STORAGE="${ANDROID_USB}/f_mass_storage"
LUN="${MASS_STORAGE}/lun"
SD_DEVICE="${PLUMOS_USB_DISK_DEVICE:-/dev/mmcblk0p1}"
STATE_DIR="${PLUMOS_USB_DISK_STATE_DIR:-/tmp/plumos-usb-disk-mode}"
LOG_FILE="${PLUMOS_USB_DISK_LOG:-/tmp/plumos-usb-disk-mode.log}"
EXIT_FLAG="${STATE_DIR}/exit"
RUN_COPY="${STATE_DIR}/plumos-usb-disk-mode.run"
USB_USERLAND_STATE="${STATE_DIR}/usb-userland"
PERSIST_LOG_FILE="${PLUMOS_ROOT}/logs/usb-disk-mode-last.log"
USB_ATTACH_GRACE_SEC="${PLUMOS_USB_DISK_ATTACH_GRACE_SEC:-30}"

mkdir -p "$STATE_DIR" 2>/dev/null || true

log() {
  printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo unknown-time)" "$*" >> "$LOG_FILE" 2>/dev/null || true
}

die() {
  log "error: $*"
  printf 'error=%s\n' "$*" >&2
  exit 1
}

read_value() {
  file="$1"
  cat "$file" 2>/dev/null || true
}

write_value() {
  file="$1"
  value="$2"
  printf '%s\n' "$value" > "$file" 2>/dev/null
}

is_mounted() {
  mount | grep -q " on ${PLUMOS_SDCARD_ROOT} "
}

save_usb_state() {
  mkdir -p "$STATE_DIR"
  read_value "${ANDROID_USB}/functions" > "${STATE_DIR}/functions"
  read_value "${ANDROID_USB}/idVendor" > "${STATE_DIR}/idVendor"
  read_value "${ANDROID_USB}/idProduct" > "${STATE_DIR}/idProduct"
  read_value "${ANDROID_USB}/enable" > "${STATE_DIR}/enable"
  read_value "${LUN}/file" > "${STATE_DIR}/lun_file"
}

restore_usb_function() {
  old_functions="$(cat "${STATE_DIR}/functions" 2>/dev/null || echo adb)"
  old_vendor="$(cat "${STATE_DIR}/idVendor" 2>/dev/null || echo 18d1)"
  old_product="$(cat "${STATE_DIR}/idProduct" 2>/dev/null || echo D002)"
  old_enable="$(cat "${STATE_DIR}/enable" 2>/dev/null || echo 1)"

  write_value "${ANDROID_USB}/enable" 0 || true
  write_value "${LUN}/file" "" || true
  write_value "${ANDROID_USB}/functions" "$old_functions" || true
  write_value "${ANDROID_USB}/idVendor" "$old_vendor" || true
  write_value "${ANDROID_USB}/idProduct" "$old_product" || true
  write_value "${ANDROID_USB}/enable" "$old_enable" || true
}

log_usb_state() {
  log "usb state=$(read_value "${ANDROID_USB}/state") functions=$(read_value "${ANDROID_USB}/functions") enabled=$(read_value "${ANDROID_USB}/enable") lun=$(read_value "${LUN}/file")"
}

print_status() {
  printf 'android_usb=%s\n' "$ANDROID_USB"
  printf 'sd_device=%s\n' "$SD_DEVICE"
  printf 'sd_mount=%s\n' "$PLUMOS_SDCARD_ROOT"
  printf 'state=%s\n' "$(read_value "${ANDROID_USB}/state")"
  printf 'functions=%s\n' "$(read_value "${ANDROID_USB}/functions")"
  printf 'enabled=%s\n' "$(read_value "${ANDROID_USB}/enable")"
  printf 'lun_file=%s\n' "$(read_value "${LUN}/file")"
  printf 'lun_ro=%s\n' "$(read_value "${LUN}/ro")"
  printf 'lun_nofua=%s\n' "$(read_value "${LUN}/nofua")"
  if is_mounted; then
    printf 'mounted=1\n'
  else
    printf 'mounted=0\n'
  fi
}

require_paths() {
  [ -d "$ANDROID_USB" ] || die "android_usb sysfs not found"
  [ -d "$MASS_STORAGE" ] || die "mass storage function not found"
  [ -e "${LUN}/file" ] || die "mass storage LUN file is missing"
  [ -b "$SD_DEVICE" ] || die "SD block device not found"
}

find_fat_fsck() {
  for name in fsck.vfat fsck.fat dosfsck; do
    if command -v "$name" >/dev/null 2>&1; then
      command -v "$name"
      return 0
    fi
    if [ -x "${PLUMOS_ROOT}/bin/${name}" ]; then
      printf '%s\n' "${PLUMOS_ROOT}/bin/${name}"
      return 0
    fi
  done
  return 1
}

has_ssh_ancestor() {
  pid=$$
  while [ "$pid" != "1" ] && [ -n "$pid" ]; do
    cmd="$(tr '\0' ' ' < "/proc/${pid}/cmdline" 2>/dev/null || true)"
    case "$cmd" in
      *dropbear*|*sshd*)
        return 0
        ;;
    esac
    ppid="$(awk '/^PPid:/ {print $2}' "/proc/${pid}/status" 2>/dev/null || true)"
    [ -n "$ppid" ] || break
    pid="$ppid"
  done
  return 1
}

sd_path_in_use_by_pid() {
  pid="$1"
  [ "$pid" = "$$" ] && return 1

  cmd="$(tr '\0' ' ' < "/proc/${pid}/cmdline" 2>/dev/null || true)"
  case "$cmd" in
    *"${PLUMOS_SDCARD_ROOT}"*) return 0 ;;
  esac

  for link in "/proc/${pid}/cwd" "/proc/${pid}/root" "/proc/${pid}/exe"; do
    target="$(readlink "$link" 2>/dev/null || true)"
    case "$target" in
      "${PLUMOS_SDCARD_ROOT}"|"${PLUMOS_SDCARD_ROOT}"/*) return 0 ;;
    esac
  done

  if grep -q "${PLUMOS_SDCARD_ROOT}/" "/proc/${pid}/maps" 2>/dev/null; then
    return 0
  fi

  for fd in "/proc/${pid}"/fd/*; do
    target="$(readlink "$fd" 2>/dev/null || true)"
    case "$target" in
      "${PLUMOS_SDCARD_ROOT}"|"${PLUMOS_SDCARD_ROOT}"/*) return 0 ;;
    esac
  done

  return 1
}

list_sd_users() {
  for proc in /proc/[0-9]*; do
    pid="${proc#/proc/}"
    case "$pid" in
      *[!0-9]*|'') continue ;;
    esac
    if sd_path_in_use_by_pid "$pid"; then
      cmd="$(tr '\0' ' ' < "/proc/${pid}/cmdline" 2>/dev/null || true)"
      comm="$(cat "/proc/${pid}/comm" 2>/dev/null || true)"
      printf 'pid=%s comm=%s cmd=%s\n' "$pid" "$comm" "$cmd"
    fi
  done
}

stop_usb_userland() {
  pids=""
  : > "$USB_USERLAND_STATE"
  for proc in /proc/[0-9]*; do
    pid="${proc#/proc/}"
    case "$pid" in
      *[!0-9]*|'') continue ;;
    esac
    [ "$pid" = "$$" ] && continue
    cmd="$(tr '\0' ' ' < "/proc/${pid}/cmdline" 2>/dev/null || true)"
    case "$cmd" in
      *'/usr/sbin/MtpDaemon -D'*|*'/usr/sbin/MtpDaemon'*)
        echo "MtpDaemon" >> "$USB_USERLAND_STATE"
        pids="$pids $pid"
        ;;
      *'/bin/adbd -D'*|*'/bin/adbd'*)
        echo "adbd" >> "$USB_USERLAND_STATE"
        pids="$pids $pid"
        ;;
    esac
  done
  if [ -n "$pids" ]; then
    log "stopping stock usb userland:${pids}"
    kill -TERM $pids 2>/dev/null || true
    sleep 1
    kill -KILL $pids 2>/dev/null || true
  fi
}

restart_usb_userland() {
  if [ -r "$USB_USERLAND_STATE" ]; then
    if grep -q '^adbd$' "$USB_USERLAND_STATE" 2>/dev/null && [ -x /bin/adbd ]; then
      log "restarting adbd"
      /bin/adbd -D >> "$LOG_FILE" 2>&1 &
    fi
    if grep -q '^MtpDaemon$' "$USB_USERLAND_STATE" 2>/dev/null &&
       [ -x /usr/sbin/MtpDaemon ]; then
      log "restarting MtpDaemon"
      /usr/sbin/MtpDaemon -D >> "$LOG_FILE" 2>&1 &
    fi
  fi
}

persist_log_if_possible() {
  if [ -d "$PLUMOS_ROOT" ]; then
    mkdir -p "${PLUMOS_ROOT}/logs" 2>/dev/null || true
    cp "$LOG_FILE" "$PERSIST_LOG_FILE" 2>/dev/null || true
  fi
}

preflight() {
  rc=0
  require_paths || rc=1
  if ! is_mounted; then
    printf 'warning=sdcard_not_mounted\n'
  fi
  if has_ssh_ancestor; then
    printf 'warning=called_from_ssh\n'
  fi
  fsck_cmd="$(find_fat_fsck 2>/dev/null || true)"
  if [ -n "$fsck_cmd" ]; then
    printf 'fsck=%s\n' "$fsck_cmd"
  else
    printf 'warning=fat_fsck_not_found\n'
  fi
  print_status
  printf 'sd_users_begin\n'
  list_sd_users
  printf 'sd_users_end\n'
  return "$rc"
}

pause_main_supervisor() {
  : > "${STATE_DIR}/main-supervisor.pids"
  ps w 2>/dev/null |
    grep -E '\{main\} /bin/sh /etc/main|/bin/sh /etc/main' |
    grep -v grep |
    sed 's/^ *//; s/ .*//' |
    while read pid; do
      case "$pid" in
        *[!0-9]*|'') continue ;;
      esac
      kill -STOP "$pid" 2>/dev/null || true
      echo "$pid" >> "${STATE_DIR}/main-supervisor.pids"
      log "paused main supervisor pid=${pid}"
    done
}

resume_main_supervisor() {
  if [ -r "${STATE_DIR}/main-supervisor.pids" ]; then
    while read pid; do
      case "$pid" in
        *[!0-9]*|'') continue ;;
      esac
      kill -CONT "$pid" 2>/dev/null || true
      log "resumed main supervisor pid=${pid}"
    done < "${STATE_DIR}/main-supervisor.pids"
  fi
}

stop_network_services() {
  if [ -x "${PLUMOS_ROOT}/bin/plumos-network-services" ]; then
    "${PLUMOS_ROOT}/bin/plumos-network-services" stop all >/dev/null 2>&1 || true
  fi
}

kill_sd_users() {
  pids=""
  for proc in /proc/[0-9]*; do
    pid="${proc#/proc/}"
    case "$pid" in
      *[!0-9]*|'') continue ;;
    esac
    [ "$pid" = "$$" ] && continue
    if sd_path_in_use_by_pid "$pid"; then
      case " $pids " in
        *" $pid "*) ;;
        *) pids="$pids $pid" ;;
      esac
    fi
  done

  if [ -n "$pids" ]; then
    log "terminating sd users:${pids}"
    kill -TERM $pids 2>/dev/null || true
    sleep 1
    kill -KILL $pids 2>/dev/null || true
  fi
}

remount_sdcard() {
  mkdir -p "$PLUMOS_SDCARD_ROOT" 2>/dev/null || true
  if is_mounted; then
    return 0
  fi
  mount "$PLUMOS_SDCARD_ROOT" 2>/dev/null || mount "$SD_DEVICE" "$PLUMOS_SDCARD_ROOT"
}

run_fsck_if_available() {
  fsck_cmd="$(find_fat_fsck 2>/dev/null || true)"
  if [ -n "$fsck_cmd" ]; then
    "$fsck_cmd" -a "$SD_DEVICE" >> "$LOG_FILE" 2>&1 || true
  fi
}

restart_plumos() {
  if [ -x "${PLUMOS_ROOT}/ssh/start-ssh.sh" ]; then
    "${PLUMOS_ROOT}/ssh/start-ssh.sh" >> "$LOG_FILE" 2>&1 &
  fi
  if [ -x "${PLUMOS_ROOT}/bin/plumos-network-services" ]; then
    "${PLUMOS_ROOT}/bin/plumos-network-services" start-enabled >> "$LOG_FILE" 2>&1 &
  fi
  resume_main_supervisor
  if [ -x /mnt/SDCARD/miyoo/app/MainUI ] &&
     [ -z "$(ps w 2>/dev/null | grep -E '/mnt/SDCARD/miyoo/app/MainUI|plumos-controller-ui-mali' | grep -v grep || true)" ]; then
    (cd /mnt/SDCARD/miyoo/app && ./MainUI >> "$LOG_FILE" 2>&1 &)
  fi
}

enable_mass_storage() {
  log "enabling USB disk mode"
  log_usb_state
  write_value "${ANDROID_USB}/enable" 0 || die "cannot disable android usb"
  write_value "${LUN}/file" "" || true
  write_value "${ANDROID_USB}/functions" "mass_storage" || die "cannot select mass_storage"
  write_value "${ANDROID_USB}/idVendor" "1f3a" || true
  write_value "${ANDROID_USB}/idProduct" "1000" || true
  write_value "${LUN}/ro" 0 || true
  write_value "${LUN}/nofua" 0 || true
  write_value "${MASS_STORAGE}/inquiry_string" "plumOS A30 SD Card" || true
  write_value "${LUN}/file" "$SD_DEVICE" || die "cannot attach SD block device"
  write_value "${ANDROID_USB}/enable" 1 || die "cannot enable android usb"
  log_usb_state
}

finish() {
  log "finishing USB disk mode"
  log_usb_state
  restore_usb_function
  run_fsck_if_available
  remount_sdcard || die "cannot remount SD card"
  restart_usb_userland
  restart_plumos
  rm -f "$EXIT_FLAG"
  log_usb_state
  log "USB disk mode finished"
  persist_log_if_possible
}

wait_for_disconnect_or_flag() {
  last_state=""
  seen_attached=0
  attach_wait_left="$USB_ATTACH_GRACE_SEC"
  case "$attach_wait_left" in
    *[!0-9]*|'') attach_wait_left=30 ;;
  esac
  log "waiting for USB attach/disconnect or ${EXIT_FLAG}"
  while :; do
    [ -e "$EXIT_FLAG" ] && break
    state="$(read_value "${ANDROID_USB}/state")"
    if [ "$state" != "$last_state" ]; then
      log "usb wait state=${state}"
      last_state="$state"
    fi
    case "$state" in
      CONNECTED|CONFIGURED) seen_attached=1 ;;
    esac
    if [ "$seen_attached" = 1 ]; then
      case "$state" in
        DISCONNECTED|NOTATTACHED|'') break ;;
      esac
    else
      if [ "$attach_wait_left" -le 0 ]; then
        log "usb attach grace expired state=${state}"
        break
      fi
      attach_wait_left=$((attach_wait_left - 1))
    fi
    sleep 1
  done
}

internal_enter() {
  require_paths
  save_usb_state
  stop_usb_userland
  sync
  stop_network_services
  pause_main_supervisor
  kill_sd_users
  sync
  umount "$PLUMOS_SDCARD_ROOT" || die "cannot unmount SD card"
  enable_mass_storage
  wait_for_disconnect_or_flag
  finish
}

enter() {
  [ "${PLUMOS_USB_DISK_MODE_EXPERIMENTAL:-0}" = "1" ] ||
    die "set PLUMOS_USB_DISK_MODE_EXPERIMENTAL=1 to enable this hidden experiment"
  [ "${PLUMOS_USB_DISK_MODE_CONFIRM:-}" = "UNMOUNT_SDCARD" ] ||
    die "set PLUMOS_USB_DISK_MODE_CONFIRM=UNMOUNT_SDCARD to acknowledge SD unmount"
  if has_ssh_ancestor && [ "${PLUMOS_USB_DISK_MODE_ALLOW_SSH:-0}" != "1" ]; then
    die "refusing to enter USB disk mode from SSH"
  fi

  mkdir -p "$STATE_DIR"
  cp "$0" "$RUN_COPY" || die "cannot stage helper in tmpfs"
  chmod 755 "$RUN_COPY"
  exec "$RUN_COPY" _enter
}

usage() {
  cat <<EOF
Usage: $0 COMMAND

Commands:
  status      Print current USB/mass-storage state.
  preflight   Check whether USB Disk Mode can be attempted.
  enter       Hidden experimental mode. Requires:
              PLUMOS_USB_DISK_MODE_EXPERIMENTAL=1
              PLUMOS_USB_DISK_MODE_CONFIRM=UNMOUNT_SDCARD
  finish      Disable mass-storage, fsck/remount SD, and restart plumOS.

USB Disk Mode exposes ${SD_DEVICE} as a USB mass-storage disk. It must stop
plumOS processes and unmount ${PLUMOS_SDCARD_ROOT}; do not use it while launched
from SSH unless you are intentionally testing recovery behavior.
EOF
}

case "${1:-}" in
  status) print_status ;;
  preflight) preflight ;;
  enter) enter ;;
  _enter) internal_enter ;;
  finish)
    [ "${PLUMOS_USB_DISK_MODE_EXPERIMENTAL:-0}" = "1" ] ||
      die "set PLUMOS_USB_DISK_MODE_EXPERIMENTAL=1 to run finish manually"
    finish
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
