@@ -33,6 +33,70 @@
 
 #if DROPBEAR_SVR_PASSWORD_AUTH
 
+#define PLUMOS_PASSWORD_HASH_FILE "/mnt/SDCARD/plumos/ssh/etc/password.hash"
+#define PLUMOS_PASSWORD_HASH_MAX 255
+
+static char *trim_field(char *value) {
+	char *end = NULL;
+
+	while (*value == ' ' || *value == '\t' || *value == '\r' || *value == '\n') {
+		value++;
+	}
+
+	end = value + strlen(value);
+	while (end > value) {
+		char c = *(end - 1);
+		if (c != ' ' && c != '\t' && c != '\r' && c != '\n') {
+			break;
+		}
+		end--;
+	}
+	*end = '\0';
+	return value;
+}
+
+static char *plumos_password_hash(const char *username) {
+	FILE *file = NULL;
+	char line[512];
+
+	file = fopen(PLUMOS_PASSWORD_HASH_FILE, "r");
+	if (file == NULL) {
+		return NULL;
+	}
+
+	while (fgets(line, sizeof(line), file) != NULL) {
+		char *entry = trim_field(line);
+		char *hash = NULL;
+		char *separator = NULL;
+
+		if (entry[0] == '\0' || entry[0] == '#') {
+			continue;
+		}
+
+		separator = strchr(entry, ':');
+		if (separator != NULL) {
+			*separator = '\0';
+			hash = trim_field(separator + 1);
+			entry = trim_field(entry);
+			if (strcmp(entry, username) != 0) {
+				continue;
+			}
+		} else {
+			hash = entry;
+		}
+
+		if (hash[0] == '\0' || strlen(hash) > PLUMOS_PASSWORD_HASH_MAX) {
+			continue;
+		}
+
+		fclose(file);
+		return m_strdup(hash);
+	}
+
+	fclose(file);
+	return NULL;
+}
+
